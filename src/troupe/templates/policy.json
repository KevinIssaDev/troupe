{
  "version": 1,
  "comment": "Troupe governance policy. protectedPaths are fnmatch patterns, matched case-insensitively against paths relative to the project root ('*' crosses directory separators). The file guard hook blocks agent writes to matching paths.",
  "protectedPaths": [
    ".troupe/casting-state.json",
    ".troupe/config.json",
    ".troupe/policy.json",
    ".troupe/agents/*/charter.md",
    ".troupe/approvals/*",
    ".troupe/.runtime/*",
    ".troupe/reeve-stop",
    ".claude/settings.json",
    ".claude/hooks/*",
    ".claude/agents/*.md",
    ".env",
    ".env.*",
    "*.pem",
    "*id_rsa*"
  ],
  "piiScrub": {
    "enabled": true,
    "allowlist": ["*@example.com", "*@example.org", "noreply@*", "no-reply@*"]
  },
  "reviewGate": {
    "enabled": false,
    "taskPatterns": ["*"]
  },
  "idleNudge": {
    "enabled": true,
    "maxNudgesPerAgent": 2
  }
}
